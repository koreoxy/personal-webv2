---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TitlePage from '../components/TitlePage.astro';
---

<Layout title="My Personal Blog">
	<main>
		<div class="flex gap-4 mt-5 mb-5">
			<Header/>
			<div class="flex flex-col gap-4 w-full">
				<TitlePage title='Home'/>
				<div class="h-full p-10 rounded-md border backdrop-blur-sm bg-white/40">
					<p>Hi there!👋 <br> I'm  Koreoxy. <br>My dream is to become a professional web developer.</p>
				
				</div>
			</div>
		</div>
		<Footer/>
	</main>
</Layout>

